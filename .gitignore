Thumbs.db
desktop.ini
.DS_Store

# Gradle
android_source/gradle-*.zip
!android_source/gradle/wrapper/gradle-wrapper.jar
!android_source/gradle/wrapper/gradle-wrapper.properties

# Logs
*.log
logs/

# Temp
*.tmp
tmp/
